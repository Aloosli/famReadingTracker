# Copy this file to `.env` and fill in what you need. Everything here is optional.

# A free Google Books API key. Book search and barcode lookup work without one, but a key
# gives higher rate limits and more reliable results.
# Create one at https://console.cloud.google.com/ (enable the "Books API").
GOOGLE_BOOKS_API_KEY=

# Where the SQLite database file lives. Defaults to data/reading-tracker.db.
# Point this at a persistent volume when deploying (the Docker image sets it to /data/...).
# DATABASE_PATH=data/reading-tracker.db

# The public URL the app is served from, e.g. https://reading.example.com.
# REQUIRED when running behind Cloudflare Tunnel or any HTTPS reverse proxy — without it, SvelteKit
# rejects POST form actions (add book, mark finished, setup) as cross-origin. Not needed for local dev.
# ORIGIN=https://reading.example.com
